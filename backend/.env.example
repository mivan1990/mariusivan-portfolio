# Copiaza acest fisier ca .env si completeaza valorile

# Secret key pentru JWT - genereaza cu: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=schimba_asta_cu_un_secret_random_lung

# Credentiale admin (pentru primul login - schimba dupa prima autentificare)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Steam Web API Key (optional - pentru avatare jucatori)
# Obtine GRATUIT de la: https://store.steampowered.com/dev/apikey
STEAM_API_KEY=

# Origins permise pentru CORS (React dev server + productie)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Director backup files CS2 (pentru citire live automata)
# Pe Windows foloseste forward slashes sau dublu backslash: W:/ sau W:\\
# Lasa gol daca nu vrei citire live
CS2_BACKUP_DIR=W:/

# Cat de des se verifica directorul (secunde, default 10)
CS2_POLL_INTERVAL=10

# Token secret pentru Game State Integration (GSI) CS2
# Genereaza cu: python -c "import secrets; print(secrets.token_hex(32))"
# Acelasi token trebuie pus in gamestate_integration_leaderboard.cfg pe serverul CS2
GSI_TOKEN=
FOOTBALL_DATA_API_KEY=
